{
  "name": "@shape-rotator/os",
  "productName": "Shape Rotator OS",
  "version": "0.3.0-rc.8",
  "private": true,
  "main": "main.js",
  "type": "commonjs",
  "description": "Shape Rotator OS — Electron app for the cohort: profile editor (PR-based), calendar, constellation, atlas, network/metrics over swf-node.",
  "homepage": "https://github.com/dmarzzz/shape-rotator-os",
  "author": {
    "name": "Shape Rotator",
    "email": "noreply@shape-rotator.local"
  },
  "scripts": {
    "start": "electron .",
    "dev": "SRWK_DEVTOOLS=1 electron .",
    "postinstall": "node scripts/link-deps.js",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "dist:all": "electron-builder -mwl",
    "pack": "electron-builder --dir",
    "check:packaging": "node scripts/check-packaging-files.js",
    "check:intel": "node scripts/check-intel-signals.cjs",
    "smoke": "electron . --smoke-test",
    "bundle:check": "node scripts/bundle-renderer.cjs --check"
  },
  "dependencies": {
    "@cosmos.gl/graph": "^2.6.4",
    "3d-force-graph": "^1.80.0",
    "electron-updater": "^6.8.3",
    "three": "^0.184.0"
  },
  "optionalDependencies": {
    "@stagetimerio/grandiose": "^0.2.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.24.2"
  },
  "build": {
    "appId": "com.shape-rotator.os",
    "productName": "Shape Rotator OS",
    "artifactName": "ShapeRotatorOS-${version}-${os}-${arch}.${ext}",
    "electronVersion": "33.4.11",
    "nodeGypRebuild": false,
    "buildDependenciesFromSource": false,
    "files": [
      "*.js",
      "daybook/**/*",
      "src/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "main.js"
    },
    "beforePack": "scripts/before-pack-stage-binaries.cjs",
    "afterPack": "scripts/after-pack-verify.cjs",
    "directories": {
      "output": "dist",
      "buildResources": "build-resources"
    },
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "owner": "dmarzzz",
        "repo": "shape-rotator-os",
        "releaseType": "release"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "darkModeSupport": true,
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build-resources/entitlements.mac.plist",
      "entitlementsInherit": "build-resources/entitlements.mac.plist",
      "notarize": false,
      "extendInfo": {
        "NSLocalNetworkUsageDescription": "Shape Rotator OS finds and syncs with other cohort members' devices on your local network — peer search, atlas, and profile sync all use this."
      },
      "extraResources": [
        {
          "from": "build-resources/swf-node/",
          "to": "swf-node/",
          "filter": [
            "**/*"
          ]
        },
        {
          "from": "build-resources/research-swarm/",
          "to": "research-swarm/",
          "filter": [
            "**/*"
          ]
        },
        {
          "from": "build-resources/cohort-keys.json",
          "to": "cohort-keys.json"
        },
        {
          "from": "build-resources/whisper/",
          "to": "whisper/",
          "filter": [
            "**/*"
          ]
        },
        {
          "from": "../../cohort-data/articles/",
          "to": "cohort-data/articles/",
          "filter": [
            "**/*.md"
          ]
        }
      ]
    },
    "dmg": {
      "title": "${productName} ${version}",
      "iconSize": 96,
      "contents": [
        {
          "x": 130,
          "y": 200,
          "type": "file"
        },
        {
          "x": 410,
          "y": 200,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "verifyUpdateCodeSignature": false,
      "extraResources": [
        {
          "from": "build-resources/swf-node/",
          "to": "swf-node/",
          "filter": [
            "**/*"
          ]
        },
        {
          "from": "build-resources/research-swarm/",
          "to": "research-swarm/",
          "filter": [
            "**/*"
          ]
        },
        {
          "from": "build-resources/cohort-keys.json",
          "to": "cohort-keys.json"
        },
        {
          "from": "build-resources/whisper/",
          "to": "whisper/",
          "filter": [
            "**/*"
          ]
        },
        {
          "from": "../../cohort-data/articles/",
          "to": "cohort-data/articles/",
          "filter": [
            "**/*.md"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "Development",
      "synopsis": "Shape Rotator OS — cohort participant viewer",
      "extraResources": [
        {
          "from": "build-resources/swf-node/",
          "to": "swf-node/",
          "filter": [
            "**/*"
          ]
        },
        {
          "from": "build-resources/research-swarm/",
          "to": "research-swarm/",
          "filter": [
            "**/*"
          ]
        },
        {
          "from": "build-resources/cohort-keys.json",
          "to": "cohort-keys.json"
        },
        {
          "from": "build-resources/whisper/",
          "to": "whisper/",
          "filter": [
            "**/*"
          ]
        },
        {
          "from": "../../cohort-data/articles/",
          "to": "cohort-data/articles/",
          "filter": [
            "**/*.md"
          ]
        }
      ]
    }
  }
}
