<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Electron requires these three under Hardened Runtime so the V8
       JIT works and the bundled .dylibs load. Without them, signed
       builds would crash at startup. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- Network access (we fetch cohort surface from GitHub + GitHub API
       for fork-aware PR routing). Without this, signed mac builds would
       silently fail to connect. -->
  <key>com.apple.security.network.client</key>
  <true/>
</dict>
</plist>
